generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  password      String
  masterSalt    String?    // PBKDF2 salt (base64), generated once on master password setup
  masterVerify  String?    // iv + encrypted "ipass-verify" combined (base64), used to verify master password
  createdAt     DateTime   @default(now())
  passwords     Password[]
}

model Password {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  url       String?
  category  String
  encrypted String   // iv + AES-GCM ciphertext combined (base64)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
